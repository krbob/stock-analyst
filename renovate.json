{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "Europe/Warsaw",
  "dependencyDashboard": true,
  "schedule": [
    "before 6am on monday"
  ],
  "updateNotScheduled": false,
  "prConcurrentLimit": 5,
  "branchConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rebaseWhen": "conflicted",
  "rangeStrategy": "pin",
  "pinDigests": true,
  "automerge": false,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 6am on monday"
    ],
    "automerge": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/ci-build\\.yml$/"
      ],
      "matchStrings": [
        "hadolint/hadolint:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "depNameTemplate": "hadolint/hadolint",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/ci-build\\.yml$/"
      ],
      "matchStrings": [
        "version:\\s*(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "description": "Group routine Python backend updates",
      "matchManagers": [
        "pip_requirements"
      ],
      "matchPackageNames": [
        "Flask",
        "flask",
        "waitress",
        "pytest"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest",
        "pin"
      ],
      "groupName": "Python backend dependencies"
    },
    {
      "description": "Require upstream-contract review for every yfinance update",
      "matchManagers": [
        "pip_requirements"
      ],
      "matchPackageNames": [
        "yfinance"
      ],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "addLabels": [
        "upstream-contract",
        "manual-review"
      ],
      "prPriority": 10
    },
    {
      "description": "Critical runtime and build providers require supply-chain review",
      "matchManagers": [
        "gradle"
      ],
      "matchPackageNames": [
        "/^org\\.jetbrains\\.kotlin/",
        "/^io\\.ktor/",
        "/^io\\.insert-koin/",
        "/^ch\\.qos\\.logback:/",
        "/^org\\.ta4j:/",
        "dev.detekt",
        "org.cyclonedx.bom"
      ],
      "automerge": false,
      "addLabels": [
        "supply-chain-review"
      ]
    },
    {
      "description": "Actions, scanners, wrapper and runtime images require manual review",
      "matchManagers": [
        "github-actions",
        "gradle-wrapper",
        "dockerfile",
        "docker-compose",
        "custom.regex"
      ],
      "automerge": false,
      "addLabels": [
        "supply-chain-review"
      ]
    },
    {
      "description": "Major updates always require manual review",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "addLabels": [
        "major-update"
      ]
    }
  ]
}
